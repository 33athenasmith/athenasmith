<style>
  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    /* Matching Light blue background */
    background-color: #e0f2fe; 
    /* Matching Minimalist white polka dots */
    background-image: radial-gradient(#ffffff 1px, transparent 1px);
    background-size: 25px 25px;
    
    color: #000;
    font-family: 'EB Garamond', serif;
    line-height: 1.6;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    min-height: 100vh;
  }

  main {
    width: 100%;
    max-width: 850px;
    padding: 3rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tabs {
    width: 100%;
    background: #fff;
    border-bottom: 1px solid #ddd;
    padding: 1rem 0;
    display: flex;
    justify-content: center;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container { display: flex; gap: 2.5rem; }

  .nav-container a {
    text-decoration: none;
    color: #555;
    font-weight: 500;
    font-size: 1.1rem;
    transition: color 0.3s;
  }

  .nav-container a:hover, .nav-container a.active {
    color: #000;
    border-bottom: 2px solid #000;
  }

  section {
    width: 100%;
    max-width: 750px;
    margin-bottom: 3.5rem;
    text-align: center;
  }

  .resume-name { font-size: 2.5rem; font-weight: 600; margin-bottom: 0.25rem; }
  .contact-info { font-size: 1.1rem; margin-bottom: 2rem; color: #444; }

  .section-title { 
    font-size: 1.3rem; 
    text-transform: uppercase;
    letter-spacing: 2px;
    border-bottom: 1px solid #333;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  h3 { font-size: 1.25rem; margin: 1rem 0 0.25rem 0; }
  
  .details { font-size: 0.95rem; font-style: italic; color: #333; margin-top: 0.25rem; }

  .item { margin-bottom: 1.5rem; }
</style>
</html>
