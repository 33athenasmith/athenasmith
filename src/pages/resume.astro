<style>
  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    background-color: #e0f2fe; /* Light blue */
    background-image: radial-gradient(#ffffff 1px, transparent 1px); /* White dots */
    background-size: 25px 25px;
    color: #000;
    font-family: 'EB Garamond', serif;
    line-height: 1.6;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    min-height: 100vh;
  }

  main {
    width: 100%;
    max-width: 850px;
    padding: 3rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tabs {
    width: 100%;
    background: #fff;
    border-bottom: 1px solid #ddd;
    padding: 1rem 0;
    display: flex;
    justify-content: center;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container { display: flex; gap: 2.5rem; }
  .nav-container a {
    text-decoration: none;
    color: #555;
    font-weight: 500;
    font-size: 1.1rem;
    transition: color 0.3s;
  }
  .nav-container a:hover, .nav-container a.active {
    color: #000;
    border-bottom: 2px solid #000;
  }

  section {
    width: 100%;
    max-width: 750px;
    margin-bottom: 3.5rem;
    text-align: left; /* Aligned left for better readability on long text */
  }

  .resume-name { font-size: 2.5rem; font-weight: 600; text-align: center; }
  .contact-info { font-size: 1.1rem; text-align: center; margin-bottom: 1rem; color: #444; }
  .summary { font-style: italic; text-align: center; margin-bottom: 2rem; color: #333; max-width: 700px; margin-inline: auto; }

  .section-title { 
    font-size: 1.2rem; 
    text-transform: uppercase;
    letter-spacing: 2px;
    border-bottom: 1.5px solid #000;
    padding-bottom: 0.3rem;
    margin-bottom: 1.2rem;
    text-align: left;
  }

  h3 { font-size: 1.2rem; margin: 1rem 0 0.2rem 0; }
  .bullet-list { margin-left: 1.5rem; margin-top: 0.5rem; }
  .bullet-list li { margin-bottom: 0.3rem; }
  .details { font-size: 0.95rem; color: #333; margin-top: 0.2rem; }
  .pub-title { font-size: 1rem; font-style: italic; margin-bottom: 0.5rem; }
  .item { margin-bottom: 1.5rem; }
</style>
</html>
