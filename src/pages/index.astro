<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Athena Smith!</title>
  <link rel="icon" type="image/png" href="https://33athenasmith.github.io/athenasmith/icon.png" />
</head>
<body>

  <nav class="tabs">
    <div class="nav-container">
      <a href="./" class="active">Home</a>
      <a href="./resume">Resume</a>
      <a href="./blog">Blog</a>
    </div>
  </nav>

  <main>
    <section class="hero">
      <h1><em>Athena Smith</em></h1>
      <h2>Government & Data Science</h2>
      <img src="./profile.jpg" alt="Athena Smith" class="profile-photo">
      
      <p class="bio">
        Hi, welcome to my website!! My name is Athena, and I am studying at the College of William & Mary!<br>
        I was born and raised in St. Petersburg, Florida, and I am interested in<br>
        international law and political destabilization.
      </p>
    </section>

    <section>
      <h2 class="section-title">Education</h2>
      <div class="item">
        <h3>College of William & Mary</h3>
        <p><strong>B.A. Major in Government, Minor in Data Science</strong> (Expected 2026)</p>
        <p>Williamsburg, Virginia</p>
      </div>
    </section>

    <section class="contact-section">
      <h2 class="section-title">Contact Me</h2>
      <form action="https://formspree.io/f/your-id-here" method="POST" class="contact-form">
        <div class="form-group">
          <input type="text" name="name" placeholder="Your Name" required>
        </div>
        <div class="form-group">
          <input type="email" name="email" placeholder="Your Email" required>
        </div>
        <div class="form-group">
          <input type="text" name="subject" placeholder="Header / Subject" required>
        </div>
        <div class="form-group">
          <textarea name="message" rows="5" placeholder="Your Message" required></textarea>
        </div>
        <button type="submit" class="submit-btn">Send Message</button>
      </form>
    </section>

  </main>

</body>

<style>
  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    background-color: #e0f2fe; 
    background-image: radial-gradient(#ffffff 1px, transparent 1px);
    background-size: 25px 25px;
    color: #000;
    font-family: 'EB Garamond', serif;
    line-height: 1.65;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    min-height: 100vh;
  }

  main {
    width: 100%;
    max-width: 850px;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tabs {
    width: 100%;
    background: #fff;
    border-bottom: 1px solid #ddd;
    padding: 1rem 0;
    display: flex;
    justify-content: center;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container { display: flex; gap: 2.5rem; }

  .nav-container a {
    text-decoration: none;
    color: #555;
    font-weight: 500;
    font-size: 1.1rem;
    transition: color 0.3s;
  }

  .nav-container a:hover, .nav-container a.active {
    color: #000;
    border-bottom: 2px solid #000;
  }

  section {
    width: 100%;
    max-width: 700px;
    margin-bottom: 4rem;
    text-align: center;
  }

  h1 { 
    font-size: 3rem; 
    font-weight: 600; 
    margin-bottom: 0.5rem; 
    letter-spacing: 4px; 
    text-transform: none; 
  }

  h1 em { font-style: italic; }

  h2 {
    font-size: 1.1rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-top: -0.8rem;
    color: #444;
  }

  .section-title { 
    font-size: 1.4rem; 
    text-transform: uppercase;
    letter-spacing: 1px;
    border-bottom: 1px solid #333;
    padding-bottom: 0.5rem;
    margin-bottom: 2rem;
    margin-top: 2rem;
  }

  h3 { font-size: 1.25rem; margin: 1.5rem 0 0.5rem 0; }

  .profile-photo {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    object-fit: cover;
    margin: 2.5rem auto;
    border: 4px solid #fef9c3; 
    display: block;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  /* --- CONTACT FORM STYLING --- */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 500px;
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.5); /* Semi-transparent white to pop against dots */
    padding: 2rem;
    border-radius: 8px;
  }

  .form-group input, .form-group textarea {
    width: 100%;
    padding: 0.8rem;
    font-family: 'EB Garamond', serif;
    font-size: 1rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    background-color: #fff;
  }

  .submit-btn {
    padding: 0.8rem;
    background-color: #000;
    color: #fff;
    border: none;
    cursor: pointer;
    font-family: 'EB Garamond', serif;
    font-size: 1.1rem;
    letter-spacing: 1px;
    transition: background 0.3s;
  }

  .submit-btn:hover {
    background-color: #333;
  }

  .item { margin-bottom: 2.5rem; }
  a { color: #000; text-decoration: underline; text-underline-offset: 3px; }
</style>
</html>
