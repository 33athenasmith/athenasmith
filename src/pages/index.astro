<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Athena Smith | Data Science</title>
</head>
<body>

  <nav class="tabs">
    <div class="nav-container">
      <a href="/" class="active">Home</a>
      <a href="/resume">Resume</a>
      <a href="/blog">Blog</a>
    </div>
  </nav>

  <main>
    <section class="hero">
      <h1>Athena Smith</h1>
      <h2>Data Science & Statistics Student</h2>
      <img src="/profile.jpg" alt="Athena Smith" class="profile-photo" />
      
      <p class="bio">
        College senior at College of William & Mary, Williamsburg, VA.<br>
        Specializing in SQL database management, Python/pandas data analysis,<br>
        statistical hypothesis testing, and international relations research.
      </p>
      
      <a href="/resume.pdf" class="btn" download>📄 Download Full Resume (PDF)</a>
    </section>

    <section>
      <h2 class="section-title">Education</h2>
      <div class="item">
        <h3>College of William & Mary</h3>
        <p><strong>B.S. Data Science & Statistics</strong> (Expected 2026)</p>
        <p>Williamsburg, Virginia</p>
      </div>
    </section>

    <section>
      <h2 class="section-title">Experience & Projects</h2>
      <div class="item">
        <h3>NYC Health Inspections Analysis</h3>
        <p>Comprehensive data pipeline using SQL queries and Python/pandas to analyze 500k+ restaurant inspection records. Performed statistical hypothesis testing and data visualization.</p>
        <p><a href="https://github.com/33athenasmith/nyc-health">View project on GitHub</a></p>
      </div>
      
      <div class="item">
        <h3>Transitional Justice Research</h3>
        <p>Researching post-conflict accountability systems and international law mechanisms for transitional justice.</p>
      </div>
    </section>
  </main>

</body>
</html>

<style>
  /* 2. STYLE: Scoped CSS goes here. No <style> tags inside <head> needed. */
  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    background: #f0f8ff;
    color: #000;
    font-family: 'EB Garamond', serif;
    line-height: 1.65;
    /* This ensures everything in the body is centered as a column */
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  main {
    width: 100%;
    max-width: 850px;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* NAVIGATION STYLING */
  .tabs {
    width: 100%;
    background: #fff;
    border-bottom: 1px solid #ddd;
    padding: 1rem 0;
    display: flex;
    justify-content: center;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-container {
    display: flex;
    gap: 2.5rem;
  }
  .nav-container a {
    text-decoration: none;
    color: #555;
    font-weight: 500;
    font-size: 1.1rem;
    transition: color 0.3s;
  }
  .nav-container a:hover, .nav-container a.active {
    color: #000;
    border-bottom: 2px solid #000;
  }

  /* CONTENT STYLING */
  section {
    width: 100%;
    max-width: 700px;
    margin-bottom: 4rem;
    text-align: center;
  }

  h1 { 
    font-size: 3rem; 
    font-weight: 600; 
    margin-bottom: 0.5rem; 
  }

  .section-title { 
    font-size: 1.4rem; 
    text-transform: uppercase;
    letter-spacing: 1px;
    border-bottom: 1px solid #333;
    padding-bottom: 0.5rem;
    margin-bottom: 2rem;
  }

  h3 { 
    font-size: 1.25rem; 
    margin: 1.5rem 0 0.5rem 0; 
  }

  .profile-photo {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    object-fit: cover;
    margin: 2rem auto;
    border: 4px solid #000;
    display: block;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  .btn {
    display: inline-block;
    margin-top: 2rem;
    padding: 12px 30px;
    background: #000;
    color: #fff;
    text-decoration: none;
    border: 2px solid #000;
    transition: all 0.3s ease;
  }

  .btn:hover {
    background: transparent;
    color: #000;
  }

  .item { margin-bottom: 2.5rem; }
  
  a { color: #000; text-decoration: underline; text-underline-offset: 3px; }
  a:hover { opacity: 0.7; }
</style>
</head>
<body>
  <!-- NAME & TITLE -->
  <section style="text-align: center; margin-bottom: 4rem;">
    <h1>Athena Smith</h1>
    <h2>Data Science & Statistics Student</h2>
    <img src="/profile.jpg" alt="Athena Smith" class="profile-photo">
    <p style="font-size: 1.15rem; max-width: 650px; margin: 0 auto;">
      College senior at College of William & Mary, Williamsburg, VA.<br>
      Specializing in SQL database management, Python/pandas data analysis,<br>
      statistical hypothesis testing, and international relations research.
    </p>
    <a href="/resume.pdf" class="btn" download>📄 Download Full Resume (PDF)</a>
  </section>

  <!-- EDUCATION -->
  <section>
    <h2>Education</h2>
    <div style="margin-bottom: 2.5rem;">
      <h3>College of William & Mary</h3>
      <p><strong>B.S. Data Science & Statistics</strong> (Expected 2026)</p>
      <p>Williamsburg, Virginia</p>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section>
    <h2>Experience & Projects</h2>
    <div style="margin-bottom: 2rem;">
      <h3>NYC Health Inspections Analysis</h3>
      <p>Comprehensive data pipeline using SQL queries and Python/pandas to analyze 500k+ restaurant inspection records. Performed statistical hypothesis testing and data visualization.</p>
      <p><a href="https://github.com/33athenasmith/nyc-health">View project on GitHub</a></p>
    </div>
    <div>
      <h3>Transitional Justice Research </h3>
      <p>Researching post-conflict accountability systems and international law mechanisms for transitional justice.</p>
    </div>
  </section>
</body>
</html>

